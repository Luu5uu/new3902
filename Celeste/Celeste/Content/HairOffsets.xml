<HairOffsets>
  <!-- idleD: 9 frames -->
  <Anim name="idled">
    <F dx="0" dy="0" />
    <F dx="0" dy="0" />
    <F dx="0" dy="0" />
    <F dx="0" dy="0" />
    <F dx="0" dy="1" />
    <F dx="0" dy="1" />
    <F dx="0" dy="1" />
    <F dx="0" dy="1" />
    <F dx="0" dy="1" />
  </Anim>

  <!-- idleA: 12 frames -->
  <Anim name="idlea">
    <F dx="0"  dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="1" />
    <F dx="-1" dy="1" />
    <F dx="-1" dy="1" />
    <F dx="-2" dy="1" />
    <F dx="-1" dy="1" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="1" />
  </Anim>

  <!-- run: 12 frames -->
  <Anim name="run">
    <F dx="1" dy="0" />
    <F dx="1" dy="1" />
    <F dx="1" dy="1" />
    <F dx="1" dy="1" />
    <F dx="1" dy="-1" />
    <F dx="1" dy="0" />
    <F dx="1" dy="1" />
    <F dx="1" dy="1" />
    <F dx="1" dy="1" />
    <F dx="1" dy="1" />
    <F dx="1" dy="-1" />
    <F dx="1" dy="0" />
  </Anim>

  <!-- dash: 4 frames -->
  <Anim name="dash">
    <F dx="2" dy="1" />
    <F dx="2" dy="1" />
    <F dx="2" dy="1" />
    <F dx="2" dy="2" />
  </Anim>

  <!-- jumpfast: 2 frames -->
  <Anim name="jumpfast">
    <F dx="1" dy="-1" />
    <F dx="1" dy="-1" />
  </Anim>

  <!-- fallslow: 2 frames -->
  <Anim name="fallslow">
    <F dx="1" dy="0" />
    <F dx="0" dy="0" />
  </Anim>

  <!-- climbup: 6 frames -->
  <Anim name="climbup">
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
  </Anim>

  <!-- dangling: 10 frames -->
  <Anim name="dangling">
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
  </Anim>

  <!-- wallslide: 1 frame -->
  <Anim name="wallslide">
    <F dx="0" dy="0" />
  </Anim>

  <!-- tired: 4 frames -->
  <Anim name="tired">
    <F dx="0"  dy="1" />
    <F dx="-1" dy="1" />
    <F dx="-1" dy="2" />
    <F dx="0"  dy="2" />
  </Anim>

  <!-- tiredstill: 1 frame -->
  <Anim name="tiredstill">
    <F dx="0" dy="2" />
  </Anim>

  <!-- climbpull: 4 frames -->
  <Anim name="climbpull">
    <F dx="0"  dy="0" />
    <F dx="0"  dy="1" />
    <F dx="-1" dy="1" />
    <F dx="-1" dy="0" />
  </Anim>

  <!-- duck: 1 frame -->
  <Anim name="duck">
    <F dx="0" dy="6" />
  </Anim>

  <!-- idleB: 24 frames -->
  <Anim name="idleb">
    <F dx="0"  dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="-1" dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="0" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="1" />
  </Anim>

  <!-- idleC: 12 frames -->
  <Anim name="idlec">
    <F dx="-1" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="-2" dy="0" />
    <F dx="2"  dy="1" />
    <F dx="3"  dy="2" />
    <F dx="0"  dy="2" />
    <F dx="-1" dy="1" />
    <F dx="0"  dy="1" />
    <F dx="0"  dy="0" />
  </Anim>

  <!-- standard: 1 frame -->
  <Anim name="standard">
    <F dx="0" dy="0" />
  </Anim>
</HairOffsets>
